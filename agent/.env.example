# ── AWS Credentials ──────────────────────────────────────────────────────────
# Required for AWS Bedrock (Claude via bedrock-runtime)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# ── Bedrock Model ID ──────────────────────────────────────────────────────────
# Model to use for inference via AWS Bedrock.
# Omit this line to use the default: global.anthropic.claude-sonnet-4-6
#
# ── Claude 4 cross-region inference profile (global.* 형식) ─────────────────
# global.anthropic.claude-opus-4-7     # 가장 강력, 가장 비쌈
# global.anthropic.claude-sonnet-4-6   # 기본값 — 성능/비용 균형 (권장)
# global.anthropic.claude-haiku-4-5    # 가장 빠르고 저렴
#
# ── Claude 3.5 (중간급, 저렴) ────────────────────────────────────────────────
# anthropic.claude-3-5-sonnet-20241022-v2:0   # Sonnet 4.6 대비 약 40% 저렴
# anthropic.claude-3-5-haiku-20241022-v1:0    # 멀티모달 지원, 가장 저렴한 Claude 3.x
#
# ── Claude 3 (레거시, 참고용) ─────────────────────────────────────────────────
# anthropic.claude-3-sonnet-20240229-v1:0  # 원본 논문 사용 모델 (신규 계정 차단됨)
# anthropic.claude-3-haiku-20240307-v1:0   # 레거시 중 가장 저렴
#
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ── SerpAPI ───────────────────────────────────────────────────────────────────
# Required for serpapi_search tool and Google AI Overview
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# ── Google Custom Search API ──────────────────────────────────────────────────
# Used by google_custom_search tool in test_dataset.py (replaces serpapi_search)
# API key: https://console.cloud.google.com/apis/credentials
# Search Engine ID (cx): https://programmablesearchengine.google.com/
#
# 복수의 API 키를 콤마(,)로 구분해 입력하면 429 Rate Limit 발생 시 자동으로 다음 키로 전환됩니다.
# 키가 1개뿐이면 그 키만 사용합니다.
#
# 단일 키:
# GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
#
# 복수 키 (fallback):
# GOOGLE_CSE_API_KEY=key1,key2,key3
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here
