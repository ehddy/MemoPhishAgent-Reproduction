# ── AWS Credentials ──────────────────────────────────────────────────────────
# Required for AWS Bedrock (Claude via bedrock-runtime)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# ── SerpAPI ───────────────────────────────────────────────────────────────────
# Required for serpapi_search tool and Google AI Overview
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# ── Google Custom Search API ──────────────────────────────────────────────────
# Used by google_custom_search tool in test_dataset.py (replaces serpapi_search)
# API key: https://console.cloud.google.com/apis/credentials
# Search Engine ID (cx): https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here
